{
  "name": "@su10/agent-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "mint-dev-token": "tsx scripts/mint-dev-token.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@su10/audit": "workspace:*",
    "@su10/config": "workspace:*",
    "@su10/db": "workspace:*",
    "@su10/errors": "workspace:*",
    "@su10/fastify-security": "workspace:*",
    "@su10/llm": "workspace:*",
    "@su10/logger": "workspace:*",
    "@su10/mail-connector": "workspace:*",
    "@su10/mcp": "workspace:*",
    "@su10/oidc": "workspace:*",
    "@su10/permissions": "workspace:*",
    "@su10/rag": "workspace:*",
    "@su10/s3": "workspace:*",
    "@su10/tools": "workspace:*",
    "@su10/tool-base": "workspace:*",
    "@su10/workflow-engine": "workspace:*",
    "@su10/workflow-schema": "workspace:*",
    "@temporalio/client": "catalog:",
    "@fastify/swagger": "catalog:",
    "@fastify/swagger-ui": "catalog:",
    "@fastify/under-pressure": "catalog:",
    "fastify": "catalog:",
    "fastify-plugin": "catalog:",
    "fastify-type-provider-zod": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@su10/tsconfig": "workspace:*",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
