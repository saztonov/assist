{
  "name": "@su10/temporal-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@su10/workflow-engine": "workspace:*",
    "@su10/agent-worker": "workspace:*",
    "@su10/db": "workspace:*",
    "@su10/document-worker": "workspace:*",
    "@su10/llm": "workspace:*",
    "@su10/s3": "workspace:*",
    "@su10/tools": "workspace:*",
    "@su10/tool-base": "workspace:*",
    "@su10/audit": "workspace:*",
    "@su10/config": "workspace:*",
    "@su10/logger": "workspace:*",
    "@su10/errors": "workspace:*",
    "@temporalio/worker": "catalog:",
    "@temporalio/client": "catalog:"
  },
  "devDependencies": {
    "@su10/tsconfig": "workspace:*",
    "@temporalio/testing": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:"
  }
}
