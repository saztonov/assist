###############################################################################
# AI/Agent Portal — .env.example  (NO REAL SECRETS — placeholders only)
#
# Real values come from Yandex Lockbox (see [LOCKBOX] tags) and are injected at
# deploy time as protected env vars / docker secrets. Never commit a real .env.
# The backend validates these at boot via @su10/config (zod, fail-fast).
###############################################################################

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# ── Database: RUNTIME user (no DDL) ──────────────────────────────────────────
DATABASE_URL=postgres://app_runtime:__FROM_LOCKBOX__@localhost:5432/agent_platform_db?sslmode=require
DATABASE_POOL_MAX=10

# ── Database: MIGRATION user (DDL; used ONLY by the deploy migration step) ────
MIGRATION_DATABASE_URL=postgres://app_migrator:__FROM_LOCKBOX__@localhost:5432/agent_platform_db?sslmode=require

# ── Temporal (workflow engine for agent tasks) ───────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-portal

# ── PostgreSQL outbox (complementary idempotent side-effect layer) ───────────
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_MAX_ATTEMPTS=10

# ── S3-compatible object storage ─────────────────────────────────────────────
S3_ENDPOINT=https://s3.example-cloud.ru
S3_REGION=ru-central1
S3_BUCKET=agent-platform-files
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=__FROM_LOCKBOX__
S3_SECRET_ACCESS_KEY=__FROM_LOCKBOX__
S3_PRESIGN_EXPIRY_SECONDS=900

# ── Keycloak / OIDC (authorization enforced on backend) ──────────────────────
OIDC_ISSUER_URL=https://auth.su10.ru/realms/portal
OIDC_CLIENT_ID=agent-api
OIDC_CLIENT_SECRET=__FROM_LOCKBOX__
OIDC_AUDIENCE=agent-api
OIDC_JWKS_URI=https://auth.su10.ru/realms/portal/protocol/openid-connect/certs

# Frontend OIDC (public client — NO secret). Consumed by Vite at build time.
VITE_OIDC_ISSUER_URL=https://auth.su10.ru/realms/portal
VITE_OIDC_CLIENT_ID=ai-portal-web
VITE_API_BASE_URL=/api

# ── LLM gateway (LM Studio reached ONLY via backend @su10/llm) ───────────────
LLM_STUDIO_BASE_URL=http://lm-studio:1234/v1
LLM_STUDIO_API_TOKEN=__FROM_LOCKBOX__
LLM_DEFAULT_MODEL=local-model
LLM_REQUEST_TIMEOUT_MS=60000
LLM_MAX_OUTPUT_TOKENS=2048

# ── RAG / pgvector ───────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=local-embed
RAG_TOP_K=8
RAG_ACL_ENFORCE=true

# ── Mail (Amazon SES primary / Yandex Postbox alternative) ───────────────────
MAIL_PROVIDER=ses
MAIL_REGION=eu-north-1
MAIL_FROM=no-reply@su10.ru
MAIL_ACCESS_KEY_ID=__FROM_LOCKBOX__
MAIL_SECRET_ACCESS_KEY=__FROM_LOCKBOX__

# ── Logging (pino) ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_HMAC_KEY=__FROM_LOCKBOX__

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Tool Broker / MCP ────────────────────────────────────────────────────────
TOOL_APPROVAL_REQUIRED_RISK=high
MCP_REGISTRY_URL=http://mcp-registry:9090
MCP_ALLOWLIST=

# ── Security misc ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
REQUEST_BODY_LIMIT_BYTES=1048576
