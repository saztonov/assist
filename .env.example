###############################################################################
# AI/Agent Portal — .env.example  (NO REAL SECRETS — placeholders only)
#
# Real values come from Yandex Lockbox (see [LOCKBOX] tags) and are injected at
# deploy time as protected env vars / docker secrets. Never commit a real .env.
# The backend validates these at boot via @su10/config (zod, fail-fast).
###############################################################################

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# ── Database: RUNTIME user (no DDL) ──────────────────────────────────────────
DATABASE_URL=postgres://app_runtime:__FROM_LOCKBOX__@localhost:5432/agent_platform_db?sslmode=require
DATABASE_POOL_MAX=10

# ── Database: MIGRATION user (DDL; used ONLY by the deploy migration step) ────
MIGRATION_DATABASE_URL=postgres://app_migrator:__FROM_LOCKBOX__@localhost:5432/agent_platform_db?sslmode=require

# ── Temporal (workflow engine for agent tasks) ───────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-portal
# true → agent-api подключает реальный @temporalio/client (нужен живой Temporal,
#         напр. `temporal server start-dev`); false → local-first in-memory stub.
# CI/локальные тесты идут на stub/фейках (no live cluster).
TEMPORAL_ENABLED=false

# ── PostgreSQL outbox (complementary idempotent side-effect layer) ───────────
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_MAX_ATTEMPTS=10

# ── S3-compatible object storage ─────────────────────────────────────────────
# Documents pipeline is OFF by default (local-first). When true, the S3_* below
# are required and validated at boot. Provider for этап 12: s3.cloud.ru.
# ВАЖНО: presigned PUT идёт из браузера (ai-portal-web), поэтому на бакете нужна
# CORS-политика, разрешающая PUT/GET с Origin фронтенда (http://localhost:5173
# для dev и прод-домен портала) и заголовок content-type.
DOCUMENTS_ENABLED=false
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central1
S3_BUCKET=agent-platform-files
# s3.cloud.ru — virtual-hosted style; при ошибках переключить на true (path-style).
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=__FROM_LOCKBOX__
S3_SECRET_ACCESS_KEY=__FROM_LOCKBOX__
S3_PRESIGN_EXPIRY_SECONDS=900

# ── Keycloak / OIDC (authorization enforced on backend) ──────────────────────
# Resource-server JWT validation needs NO client secret (public JWKS only).
OIDC_ISSUER=https://auth.su10.ru/realms/portal
OIDC_JWKS_URI=https://auth.su10.ru/realms/portal/protocol/openid-connect/certs
OIDC_AUDIENCE=agent-api
OIDC_CLIENT_ID=agent-api
OIDC_RESOURCE_CLIENT=agent-api
OIDC_CLOCK_TOLERANCE_S=5
# LOCAL-FIRST ONLY (never prod): inline public JWKS printed by
#   pnpm --filter @su10/agent-api mint-dev-token
# When set, the API verifies dev tokens locally without a live Keycloak.
# OIDC_DEV_JWKS={"keys":[...]}

# Frontend OIDC (public client — NO secret). Consumed by Vite at build time.
# Если VITE_OIDC_ISSUER_URL и VITE_OIDC_CLIENT_ID заданы → ai-portal-web включает
# OIDC PKCE-вход; иначе работает dev-token режим (localStorage `dev_token`).
# Keycloak: public client с Standard flow (PKCE), redirect URI = VITE_OIDC_REDIRECT_URI
# (для dev — http://localhost:5173), audience mapper добавляет `agent-api` в aud.
VITE_OIDC_ISSUER_URL=https://auth.su10.ru/realms/portal
VITE_OIDC_CLIENT_ID=ai-portal-web
VITE_OIDC_REDIRECT_URI=http://localhost:5173
VITE_OIDC_SCOPE=openid profile email
VITE_API_BASE_URL=/api

# ── LLM gateway (LM Studio reached ONLY via backend @su10/llm) ───────────────
# Canonical names; aliases LMSTUDIO_BASE_URL / LM_STUDIO_API_TOKEN are accepted.
LLM_STUDIO_BASE_URL=http://lm-studio:1234/v1
LLM_STUDIO_API_TOKEN=__FROM_LOCKBOX__
# LM Studio model ids (routing): OCR → chandra, JSON → lift, analysis → qwen.
CHANDRA_MODEL=chandra-ocr-2
LIFT_MODEL=lift
QWEN_MODEL=qwen36-27b-mtp
# Default model per task class (when a caller does not pin a model).
LLM_DEFAULT_CHAT_MODEL=qwen36-27b-mtp
LLM_DEFAULT_OCR_MODEL=chandra-ocr-2
LLM_DEFAULT_EXTRACTION_MODEL=lift
# Per-model concurrency caps (skill limits).
LLM_MAX_PARALLEL_CHANDRA=4
LLM_MAX_PARALLEL_LIFT=4
LLM_MAX_PARALLEL_QWEN=1
# Timeout / bounded retry.
LLM_TIMEOUT_MS_DEFAULT=300000
LLM_MAX_RETRIES=3

# ── RAG / pgvector ───────────────────────────────────────────────────────────
# Embedding provider is SEPARATE from chat/vision models. `mock` = local-first
# default; it is REJECTED in production (an approved provider is required).
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embed
EMBEDDING_DIM=768
RAG_TOP_K=8
RAG_ACL_ENFORCE=true

# ── Mail SEND (Amazon SES primary / Yandex Postbox alternative) ──────────────
# Outbound-only; UNUSED by the read-only mail CONNECTOR below (which never sends).
MAIL_PROVIDER=ses
MAIL_REGION=eu-north-1
MAIL_FROM=no-reply@su10.ru
MAIL_ACCESS_KEY_ID=__FROM_LOCKBOX__
MAIL_SECRET_ACCESS_KEY=__FROM_LOCKBOX__

# ── Mail CONNECTOR (read-only IMAP; drafts via APPEND, NEVER sends) ──────────
# Generic IMAP (Yandex 360 / a box fed by Yandex Cloud Postbox or Cloudflare
# Email Routing / self-hosted). Enabling requires S3 (attachments → S3). Per-
# account host/user live in connector_accounts.metadata_json; credentials are a
# secret_ref only (e.g. env:MAIL_ACC_<id>_APP_PASSWORD) — never a raw secret.
MAIL_CONNECTOR_ENABLED=false
MAIL_IMAP_DEFAULT_HOST=imap.yandex.ru
MAIL_IMAP_DEFAULT_PORT=993
MAIL_IMAP_DEFAULT_SECURE=true
MAIL_IMAP_DEFAULT_DRAFTS_MAILBOX=Drafts
MAIL_RATE_LIMIT_CAPACITY=10
MAIL_RATE_LIMIT_REFILL_PER_SEC=2
MAIL_MAX_ATTACHMENT_BYTES=26214400
MAIL_BODY_MAX_CHARS=50000
# Dev/test mailbox app-password, referenced by an account's secret_ref=env:MAIL_TEST_APP_PASSWORD
MAIL_TEST_APP_PASSWORD=__FROM_LOCKBOX__

# ── Logging (pino) ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_HMAC_KEY=__FROM_LOCKBOX__

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Tool Broker / MCP ────────────────────────────────────────────────────────
TOOL_APPROVAL_REQUIRED_RISK=high
MCP_REGISTRY_URL=http://mcp-registry:9090
MCP_ALLOWLIST=

# ── agent-api HTTP surface ───────────────────────────────────────────────────
API_PREFIX=/api/v1
TRUST_PROXY=false
CORS_ALLOWED_ORIGINS=http://localhost:5173
BODY_LIMIT=1048576
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
ALLOWED_SOURCE_PORTALS=
OPENAPI_ENABLED=true
OPENAPI_UI_ENABLED=false

# ── Readiness probes (local-first: OFF by default, no egress in buildApp) ────
# DB probe runs `SELECT 1` against DATABASE_URL only when enabled (stage 3).
DB_READYCHECK_ENABLED=false
# ── LLM readiness probe (uses @su10/llm gateway.healthCheck) ─────────────────
LLM_READYCHECK_ENABLED=false
