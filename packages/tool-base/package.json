{
  "name": "@su10/tool-base",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@su10/db": "workspace:*",
    "@su10/errors": "workspace:*",
    "@su10/permissions": "workspace:*",
    "@su10/tools": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@su10/tsconfig": "workspace:*",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:"
  }
}
