{
  "name": "@su10/fastify-security",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@su10/config": "workspace:*",
    "@su10/logger": "workspace:*",
    "@su10/errors": "workspace:*",
    "@su10/oidc": "workspace:*",
    "@fastify/helmet": "catalog:",
    "@fastify/cors": "catalog:",
    "@fastify/rate-limit": "catalog:",
    "fastify-plugin": "catalog:",
    "fastify-type-provider-zod": "catalog:"
  },
  "devDependencies": {
    "@su10/tsconfig": "workspace:*",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "fastify": "catalog:",
    "pino": "catalog:"
  }
}
